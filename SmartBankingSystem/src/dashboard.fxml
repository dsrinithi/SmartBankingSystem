<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>

<BorderPane
    xmlns="http://javafx.com/javafx"
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="Controller.DashboardController">

    <top>
        <HBox spacing="20" alignment="CENTER"
              styleClass="header">

            <Label text="🏦 SMART BANK"
                   styleClass="title"/>

            <Label fx:id="welcomeLabel"
                   text="Welcome"/>
                   
            <Label fx:id="dateTimeLabel"/>
           
        </HBox>
    </top>

    <center>

        <VBox spacing="20"
              alignment="CENTER">

            <Label text="Current Balance"
                   styleClass="balanceTitle"/>

            <Label fx:id="message"
                   text="₹ 0"
                   styleClass="balanceValue"/>

            <HBox spacing="15"
                  alignment="CENTER">

                <Button text="💰 Deposit"
                        onAction="#openDeposit"
                        styleClass="cardBtn"/>

                <Button text="💸 Withdraw"
                        onAction="#openWithdraw"
                        styleClass="cardBtn"/>

                <Button text="📊 Balance"
                        onAction="#checkBalance"
                        styleClass="cardBtn"/>

                <Button text="📜 History"
                        onAction="#loadHistory"
                        styleClass="cardBtn"/>

            </HBox>

            <TableView fx:id="tableView"
                       prefWidth="900"
                       prefHeight="300">

                <columns>

                    <TableColumn fx:id="dateCol"
                                 text="Date"/>

                    <TableColumn fx:id="typeCol"
                                 text="Type"/>

                    <TableColumn fx:id="amountCol"
                                 text="Amount"/>

                </columns>

            </TableView>

            <HBox spacing="15"
                  alignment="CENTER">

                <Button text="👤 Profile"
                        onAction="#showProfile"/>

                <Button text="📈 Analytics"
                        onAction="#showPieChart"/>

                <Button text="🌙 Dark Mode"
                        onAction="#toggleTheme"/>

            </HBox>

            <Button text="🚪 Logout"
                    onAction="#logout"/>

        </VBox>

    </center>

</BorderPane>