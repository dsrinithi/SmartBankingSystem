<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER"
      spacing="10"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="RegisterController.Registercontroller">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Create New Account"/>

    <TextField fx:id="name"
               promptText="Full Name"/>

    <TextField fx:id="user"
               promptText="Username"/>

    <PasswordField fx:id="pass"
                   promptText="Password"/>

    <TextField fx:id="mobile"
               promptText="Mobile Number"/>

    <TextField fx:id="deposit"
               promptText="Opening Balance"/>

    <Label fx:id="msg"/>

    <Button text="Register"
            onAction="#register"/>

    <Button text="Back To Login"
            onAction="#backToLogin"/>

</VBox>